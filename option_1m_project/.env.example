TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
MONGODB_URI=your_mongodb_connection_string
MONGODB_DATABASE=option_1m_bot
MONGODB_COLLECTION=bot_state
MONGODB_PAPER_TRADES_COLLECTION=paper_trades
MONGODB_SIGNAL_ALERTS_COLLECTION=signal_alerts

STRATEGY_MODE=option_contracts
OPTION_CONTRACT_1=
OPTION_CONTRACT_2=
OPTION_CONTRACT_INTERVAL=1m
OPTION_CONTRACT_SIGNAL_MODE=both
OPTION_CONTRACT_ENTRY_SIGNAL=BUY
OPTION_CONTRACT_TARGET_PCT=3
OPTION_CONTRACT_MAX_SIGNAL_CANDLE_PCT=10
OPTION_CONTRACT_STOP_LOSS_MODE=signal_low
OPTION_CONTRACT_STOP_LOSS_PCT=8

TIMEZONE=Asia/Kolkata
SCHEDULE_START_IST=09:20
SCHEDULE_END_IST=15:00
SCHEDULE_INTERVAL_MINUTES=1
SCHEDULE_BUFFER_SECONDS=2
FORCE_WEEKEND_RUNS=false

PAPER_TRADE_CAPITAL=100000
PAPER_TRADE_LOT_SIZE=75
PAPER_TRADE_SLIPPAGE_PCT=0.0
PAPER_TRADE_TARGET_PCT=3
PAPER_TRADE_MAX_SL_PCT=15
PAPER_TRADE_DAILY_PROFIT_STOP_PCT=15
PAPER_TRADE_MONITOR_SECONDS=3
PAPER_TRADE_ENTRY_SECOND=2

NIFTY_SYMBOL=^NSEI
NIFTY_INTERVAL=5m
NIFTY_PERIOD=5d
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REDIRECT_URL=http://127.0.0.1:8100/kite/callback
ZERODHA_OPTION_EXCHANGE=NFO
ZERODHA_UNDERLYING=NIFTY
ZERODHA_ENABLE_WEBSOCKET=true
ZERODHA_QUOTE_TIMEOUT_SECONDS=2.0

LEGACY_STATE_FILE=bot_state.json
RUN_LOGS_DIR=logs/run_logs
LOG_FILE=logs/option_1m_bot.log
