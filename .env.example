TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
MONGODB_URI=your_mongodb_connection_string
MONGODB_DATABASE=nifty_alert_bot
MONGODB_COLLECTION=bot_state
MONGODB_LOGS_COLLECTION=run_logs_archive
MONGODB_PAPER_TRADES_COLLECTION=paper_trades
NIFTY_SYMBOL=^NSEI
NIFTY_INTERVAL=5m
NIFTY_PERIOD=5d
TIMEZONE=Asia/Kolkata
SCHEDULE_START_IST=09:55
SCHEDULE_END_IST=13:30
SCHEDULE_INTERVAL_MINUTES=5
SCHEDULE_BUFFER_SECONDS=10
PAPER_TRADE_CAPITAL=100000
PAPER_TRADE_LOT_SIZE=75
PAPER_TRADE_SLIPPAGE_PCT=0.75
PAPER_TRADE_TARGET_PCT=8
PAPER_TRADE_MAX_SL_PCT=8
PAPER_TRADE_MONITOR_SECONDS=5
PAPER_TRADE_ENTRY_SECOND=55
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REDIRECT_URL=http://127.0.0.1:8000/kite/callback
ZERODHA_OPTION_EXCHANGE=NFO
ZERODHA_UNDERLYING=NIFTY
ZERODHA_ENABLE_WEBSOCKET=true
ZERODHA_QUOTE_TIMEOUT_SECONDS=2.0
STATE_FILE=bot_state.json
RUN_LOGS_DIR=logs/run_logs
LOG_FILE=logs/nifty_alert_bot.log
